{
  "version": "1.0.0",
  "layout_name": "_user_base",
  "meta": {
    "title": "$t:common.site_name",
    "description": "$t:common.site_tagline",
    "is_base": true,
    "seo": {
      "enabled": true,
      "og": {
        "type": "website"
      }
    }
  },
  "data_sources": [],
  "components": [
    {
      "id": "layout_root",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "gallery-shell"
      },
      "children": [
        {
          "id": "site_header",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "gallery-header"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "gallery-container gallery-header-inner"
              },
              "children": [
                {
                  "partial": "partials/common/_header_brand.json"
                },
                {
                  "partial": "partials/common/_header_nav.json"
                }
              ]
            }
          ]
        },
        {
          "id": "main_content_area",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "gallery-main"
          },
          "children": [
            {
              "id": "main_content_inner",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "gallery-container gallery-section"
              },
              "children": [
                {
                  "id": "content_slot",
                  "type": "basic",
                  "name": "Div",
                  "slot": "content",
                  "props": {
                    "className": "gallery-content-slot"
                  },
                  "children": []
                }
              ]
            }
          ]
        },
        {
          "id": "site_footer",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "gallery-footer"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "gallery-container gallery-footer-inner"
              },
              "children": [
                {
                  "partial": "partials/common/_footer_info.json"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
