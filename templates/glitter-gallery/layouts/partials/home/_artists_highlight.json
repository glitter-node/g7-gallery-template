{
  "layout_name": "glitter_gallery_partial_home_artists_highlight",
  "type": "basic",
  "name": "Section",
  "props": {
    "className": "gallery-stack"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "gallery-section-heading"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "text": "작가 하이라이트",
          "props": {
            "className": "gallery-kicker"
          }
        },
        {
          "type": "basic",
          "name": "H2",
          "text": "공간의 결을 함께 만드는 작가들",
          "props": {
            "className": "gallery-title-lg"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "gallery-card-grid"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "iteration": {
            "source": "{{featured_artists.data ?? []}}",
            "item_var": "item"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "gallery-card gallery-card-muted"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "gallery-card-media"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "{{item.role ?? '작가'}}",
                  "props": {
                    "className": "gallery-meta"
                  }
                },
                {
                  "type": "basic",
                  "name": "H3",
                  "text": "{{item.name ?? $t:pages.fallback_title}}",
                  "props": {
                    "className": "gallery-title-md"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "text": "{{item.summary ?? $t:pages.fallback_description}}",
                  "props": {
                    "className": "gallery-body"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
