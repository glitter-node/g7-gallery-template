{
  "layout_name": "glitter_gallery_partial_home_collection_grid",
  "type": "basic",
  "name": "Section",
  "props": {
    "className": "gallery-stack"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "gallery-section-heading"
      },
      "children": [
        {
          "type": "basic",
          "name": "Span",
          "text": "소장품",
          "props": {
            "className": "gallery-kicker"
          }
        },
        {
          "type": "basic",
          "name": "H2",
          "text": "작품 카드 그리드",
          "props": {
            "className": "gallery-title-lg"
          }
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "gallery-card-grid gallery-grid-three"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "iteration": {
            "source": "{{featured_collection.data ?? []}}",
            "item_var": "item"
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "gallery-card"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "gallery-card-media"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "{{item.meta ?? ''}}",
                  "props": {
                    "className": "gallery-meta"
                  }
                },
                {
                  "type": "basic",
                  "name": "H3",
                  "text": "{{item.title ?? $t:pages.fallback_title}}",
                  "props": {
                    "className": "gallery-title-md"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "text": "{{item.description ?? $t:pages.fallback_description}}",
                  "props": {
                    "className": "gallery-body"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
